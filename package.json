{
  "name": "streamops-agent",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered operations agent for streaming pipelines",
  "scripts": {
    "build:java": "cd java && mvn clean package -DskipTests",
    "build:java:test": "cd java && mvn clean verify",
    "build:proto": "cd java && mvn compile -pl proto",

    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "infra:logs": "docker compose logs -f",
    "infra:status": "docker compose ps",

    "sim:run": "java -jar java/event-simulator/target/event-simulator-0.1.0-SNAPSHOT.jar",
    "sim:latency": "java -jar java/event-simulator/target/event-simulator-0.1.0-SNAPSHOT.jar latency-spike",
    "sim:errors": "java -jar java/event-simulator/target/event-simulator-0.1.0-SNAPSHOT.jar error-burst",
    "sim:backpressure": "java -jar java/event-simulator/target/event-simulator-0.1.0-SNAPSHOT.jar backpressure",

    "flink:submit": "docker compose exec flink-jobmanager flink run /opt/flink/jobs/stream-processor.jar",
    "flink:list": "docker compose exec flink-jobmanager flink list",
    "flink:cancel": "docker compose exec flink-jobmanager flink cancel",
    "flink:ui": "echo 'Flink UI: http://localhost:8081'",

    "grafana:open": "echo 'Grafana: http://localhost:3000 (admin/streamops)'",
    "prometheus:open": "echo 'Prometheus: http://localhost:9090'"
  }
}
